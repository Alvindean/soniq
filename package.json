// FUSION MATRIX + QUALITY PREDICTOR
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
const FG=['Pop','Hip-Hop','R&B','K-Pop','EDM','Latin','Reggaeton','Singer-Songwriter','Alt-Rock','Reggae','Afrobeats','Blues','Punk'];

function scoreColor(s){
  if(!s)return{bg:'#111118',t:'#303040'};
  if(s>=93)return{bg:'#0a2818',t:'#40c880'};
  if(s>=88)return{bg:'#0c2010',t:'#35a868'};
  if(s>=82)return{bg:'#112016',t:'#2a8850'};
  if(s>=76)return{bg:'#141a14',t:'#1e6840'};
  return{bg:'#121610',t:'#185030'};
}

function initFusion(){
  const el=document.getElementById('fm');if(el.innerHTML)return;
  const n=FG.length;
  let html=`<div class="fgrid" style="grid-template-columns:58px repeat(${n},1fr)">`;
  html+='<div></div>';
  FG.forEach(g=>{html+=`<div class="fax" style="font-size:8px;font-weight:700;color:var(--tx4);padding:3px 2px;text-align:center;line-height:1.2">${g}</div>`;});
  FG.forEach((g1,i)=>{
    html+=`<div class="fax row" style="font-size:8px;font-weight:700;color:var(--tx4);text-align:right;padding-right:4px">${g1}</div>`;
    FG.forEach((g2,j)=>{
      if(i===j){html+=`<div class="fc empty">â€”</div>`;return;}
      const k1=`${g1}+${g2}`,k2=`${g2}+${g1}`;
      const fd=FUSION_DATA[k1]||FUSION_DATA[k2];
      const score=fd?.q?.overall;
      const c=scoreColor(score);
      const lbl=fd?fd.name.split(' ').slice(0,2).join(' '):'?';
      html+=`<div class="fc" style="background:${c.bg};color:${c.t}" onclick="showFusion('${g1}','${g2}')">
        <div>${lbl}</div>
        ${score?`<div class="fc-score">${score}</div>`:''}
      </div>`;
    });
  });
  html+='</div>';
  el.innerHTML=html;
}

function showFusion(g1,g2){
  const k1=`${g1}+${g2}`,k2=`${g2}+${g1}`;
  const fd=FUSION_DATA[k1]||FUSION_DATA[k2];
  S.currentFusion={g1,g2,fd};
  const panel=document.getElementById('fd-panel');
  panel.className='fdpanel on';
  document.getElementById('fd-name').textContent=fd?fd.name:`${g1} أ— ${g2}`;
  document.getElementById('fd-genres-lbl').textContent=`${g1} أ— ${g2} fusion`;
  document.getElementById('fd-artists').textContent=fd?.artists||'Experimental â€” click Generate to explore';
  document.getElementById('fd-tip').textContent=fd?.tip||'Click Generate to discover this fusion';
  document.getElementById('fd-formula').textContent=fd?.formula||'Click Generate Fusion Song to explore this combination';
  document.getElementById('fd-out').innerHTML='';

  if(fd?.q){
    const q=fd.q;
    const oc=q.overall>=90?'var(--green)':q.overall>=80?'var(--amber)':'var(--red)';
    document.getElementById('fd-qring').innerHTML=`
      <div class="qrcircle" style="border-color:${oc}">
        <div class="qrnum" style="color:${oc}">${q.overall}</div>
        <div class="qrlabel" style="color:${oc}">Quality</div>
      </div>
      <div class="qbars">
        ${[['Compatibility',q.compat,'var(--cyan)'],['Proven examples',q.examples,'var(--green)'],['Structural fit',q.structural,'var(--violet)'],['Commercial',q.commercial,'var(--amber)']].map(([l,v,c])=>`<div class="qbrow"><div class="qblabel">${l}</div><div class="qbbar"><div class="qbfill" style="width:${v}%;background:${c}"></div></div><div class="qbval">${v}</div></div>`).join('')}
      </div>`;
  }else{
    document.getElementById('fd-qring').innerHTML='<div style="font-size:12px;color:var(--tx3);padding:8px 0">Experimental fusion â€” no quality data yet.</div>';
  }
  panel.scrollIntoView({behavior:'smooth',block:'nearest'});
}

async function generateFusion(){
  const {g1,g2,fd}=S.currentFusion||{};
  if(!g1)return;
  const prompt=`Write a complete ${g1} أ— ${g2} genre fusion song.\n\n${fd?`Fusion style: ${fd.name}\nFormula: ${fd.formula}`:`Experimental fusion of ${g1} and ${g2}. Define what makes it work and write accordingly.`}\n\nRespond with EXACTLY this format:\n\nTITLE: [song title]\n\nLYRICS:\n[full lyrics with all section tags]\n\nSONG PROMPT:\n[under 180 chars, specific instruments, no artist names]\n\nFUSION EXPLANATION:\n[2-3 sentences on how the two genres combine and what makes it work]`;

  btnLoad('fd-gen-btn','Writingâ€¦');
  document.getElementById('fd-out').innerHTML='<div style="display:flex;align-items:center;gap:8px;padding:12px 0"><span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span><span class="ld-msg">Generating fusion songâ€¦</span></div>';

  try{
    const raw=await callClaude(prompt,'You are an expert songwriter specializing in genre fusion. Write only the formatted output requested.');
    const title=parseSection(raw,'TITLE','LYRICS');
    const lyrics=parseSection(raw,'LYRICS','SONG PROMPT');
    const style=parseSection(raw,'SONG PROMPT','FUSION EXPLANATION');
    const expl=parseSection(raw,'FUSION EXPLANATION',null);
    document.getElementById('fd-out').innerHTML=`
      <div style="border-top:1px solid var(--b1);margin-top:14px;padding-top:14px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px">
          <div style="font-size:16px;font-weight:700">"${title}"</div>
          <div style="display:flex;gap:6px">
            <button class="btn btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('fd-lyr').textContent).then(()=>toast('âœ“ Copied'))">Copy Lyrics</button>
            <button class="btn btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('fd-sty').textContent).then(()=>toast('âœ“ Copied'))">Copy Style</button>
          </div>
        </div>
        <pre id="fd-lyr" style="font-family:var(--mono);font-size:12px;line-height:2;color:var(--tx2);white-space:pre-wrap;background:var(--bg1);border:1px solid var(--b1);border-radius:var(--r);padding:12px 14px;margin-bottom:10px">${lyrics}</pre>
        <div class="styleout" id="fd-sty" style="margin-bottom:10px">${style}</div>
        <div style="font-size:13px;color:var(--tx2);line-height:1.7;font-style:italic">${expl}</div>
      </div>`;
    toast('âœ“ Fusion song generated');
  }catch(e){
    document.getElementById('fd-out').innerHTML=`<div style="color:var(--red);font-size:13px;padding:8px 0">âڑ ï¸ڈ ${e.message}</div>`;
    toast('âڑ ï¸ڈ Generation failed',3000);
  }
  btnDone('fd-gen-btn');
}

