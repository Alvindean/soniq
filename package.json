function selSong(i){
  const genre=document.getElementById('a-genre').value;
  document.querySelectorAll('.sgcard').forEach(c=>c.classList.remove('on'));
  document.getElementById('asc'+i)?.classList.add('on');
  S.selectedSong=SONGS[genre]?.[i];
  document.getElementById('a-sel').textContent=`Selected: "${S.selectedSong?.t}" â€” click Analyze`;
