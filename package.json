async function runAnalysis(){
  const genre=document.getElementById('a-genre').value;
  const genreLabel=document.getElementById('a-genre').options[document.getElementById('a-genre').selectedIndex].text;
  const focus=document.getElementById('a-focus').value;
  const songs=SONGS[genre]||[];
  const sel=S.selectedSong;
  const songList=sel?`"${sel.t}" by ${sel.a} (${sel.yr}). Structure: ${sel.structure}. Notes: ${sel.key}`:songs.map(s=>`â€¢ "${s.t}" by ${s.a} (${s.yr}) â€” ${s.structure}`).join('\n');
  const prompt=`Analyze these ${genreLabel} songs as a musicologist, neuroscientist, and hit songwriter:\n\n${songList}\n\nFocus: ${focus}\n\nProvide:\n1. STRUCTURAL PATTERNS â€” sections, bar counts, timing\n2. PSYCHOLOGICAL WHY â€” dopamine, Zeigarnik, prediction error, tension-release\n3. LYRIC PATTERNS â€” rhyme schemes, syllable density, imagery, emotional arc\n4. WHY IT HIT â€” the 2-3 specific elements that made this cross over\n5. RATINGS â€” Hook/Structure/Emotion/Lyrics/Commercial (each 1-10) per song\n6. SONGWRITER TAKEAWAYS â€” 3 immediately actionable insights`;
  btnLoad('a-btn','Analyzingâ€¦');
  document.getElementById('a-out').innerHTML='<div class="card"><div style="display:flex;align-items:center;gap:8px;padding:8px 0"><span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span><span class="ld-msg">Analyzing songsâ€¦</span></div></div>';
