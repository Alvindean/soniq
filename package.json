// SUNO PROMPT BUILDER
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
function initBuilder(){
  if(document.getElementById('pb-genre').innerHTML)return;
  const genres=['pop','hip-hop','R&B','rock','country','EDM','folk','latin','metal','jazz','singer-songwriter','alt-rock','reggae','afrobeats','blues','punk'];
  document.getElementById('pb-genre').innerHTML=genres.map(g=>`<div class="pbopt" onclick="pbSingle(this,'genre')">${g}</div>`).join('');
  const instrs=['acoustic guitar','electric guitar','piano','synth','808 bass','upright bass','live drums','brushed snare','violin','cello','trumpet','saxophone','harmonica','banjo','organ','flute','talking drum','congas','hi-hats','ambient pads'];
  document.getElementById('pb-instr').innerHTML=instrs.map(i=>`<div class="pbopt multi" onclick="pbMultiLimit(this,'instr',4)">${i}</div>`).join('');
  const voices=[
    {n:'Smoky jazz female',d:'sultry female vocals, jazzy, breathy'},
    {n:'Soulful gospel female',d:'powerful soulful female vocals, gospel runs'},
    {n:'Intimate bedroom pop',d:'soft intimate female vocals, close mic'},
    {n:'Arena rock male',d:'powerful male vocals, gritty, anthemic'},
    {n:'Raspy blues male',d:'raspy male vocals, blues growl, emotional'},
    {n:'Trap melodic auto',d:'autotune male vocals, melodic trap delivery'},
    {n:'Conscious rap male',d:'clear articulate male rap, lyrical flow'},
    {n:'Reggae toaster',d:'reggae toasting, Jamaican patois, relaxed'},
    {n:'Punk aggression',d:'raw aggressive male punk vocals, no-fi'},
    {n:'Falsetto indie male',d:'high falsetto male vocals, indie folk'},
    {n:'Deep folk baritone',d:'deep warm baritone, folk storyteller'},
    {n:'Afrobeats smooth',d:'smooth Nigerian vocals, melodic pidgin'},
  ];
  document.getElementById('pb-voices').innerHTML=voices.map(v=>`<div class="vcard" onclick="pbVoice(this,'${v.d}')"><div class="vc-name">${v.n}</div><div class="vc-desc">${v.d}</div></div>`).join('');
  updBuilderPrompt();
}
function pbSingle(el,group){el.parentElement.querySelectorAll('.pbopt').forEach(o=>o.classList.remove('on'));el.classList.add('on');S.pb[group]=el.textContent.trim();updBuilderPrompt();}
function pbMulti(el,group){el.classList.toggle('on');S.pb[group]=Array.from(el.parentElement.querySelectorAll('.on')).map(e=>e.textContent.trim());updBuilderPrompt();}
function pbMultiLimit(el,group,limit){
  const cur=el.parentElement.querySelectorAll('.on').length;
  if(!el.classList.contains('on')&&cur>=limit){toast(`Max ${limit} â€” deselect one first`);return;}
  el.classList.toggle('on');S.pb[group]=Array.from(el.parentElement.querySelectorAll('.on')).map(e=>e.textContent.trim());updBuilderPrompt();
}
function pbVoice(el,desc){document.querySelectorAll('.vcard').forEach(c=>c.classList.remove('on'));el.classList.add('on');S.pb.voice=desc;updBuilderPrompt();}
function pbBpm(inp){
  S.pb.bpm=parseInt(inp.value);
  const lbl=document.getElementById('pb-bpm-lbl');
  if(lbl) lbl.textContent=S.pb.bpm+' BPM';
  updBuilderPrompt();
}
function updBuilderPrompt(){
  const parts=[];
  if(S.pb.genre)parts.push(S.pb.genre);
  if(S.pb.era)parts.push(S.pb.era);
  if(S.pb.bpm&&S.pb.bpm!==100)parts.push(S.pb.bpm+' BPM');
  if(S.pb.instr?.length)parts.push(S.pb.instr.join(', '));
  if(S.pb.energy)parts.push(S.pb.energy);
  if(S.pb.texture?.length)parts.push(S.pb.texture.join(', '));
  if(S.pb.voice)parts.push(S.pb.voice);
  const prompt=parts.filter(Boolean).join(', ');
  const previewEl=document.getElementById('pb-preview');
  const ccEl=document.getElementById('pb-cc');
  if(previewEl) previewEl.textContent=prompt||'Select options above to generate your song production promptâ€¦';
  const len=prompt.length;
  if(ccEl){
    ccEl.textContent=len+'/200';
    ccEl.className='ppcount '+(len>200?'over':len>160?'warn':'ok');
  }
}
function copyBuilderPrompt(){
  const el=document.getElementById('pb-preview');
  const text=el?.textContent||'';
  if(!text||text.includes('Select options')){toast('Build a prompt first â€” select at least one option above');return;}
  navigator.clipboard.writeText(text).then(()=>toast('âœ“ Style prompt copied'));
}

