function updBlendDesc(){
  const g2sel=document.getElementById('g-genre2');
  const s2sel=document.getElementById('g-style2');
  if(!g2sel||!s2sel)return;
  S.blend.genre2=g2sel.value;
  S.blend.style2=s2sel.value;
  const badge=document.getElementById('blend-active-badge');
  const chip=document.getElementById('blend-preview-chip');
  if(!S.blend.genre2&&!S.blend.style2){
    if(badge)badge.style.display='none';
    if(chip)chip.textContent='Add a 2nd style to create unique hybrid writing';
    document.getElementById('blend-desc').textContent='';
    return;
  }
  if(badge)badge.style.display='inline-block';
  const g2label=g2sel.options[g2sel.selectedIndex]?.text||'';
  const s2label=s2sel.options[s2sel.selectedIndex]?.text||'';
  const parts=[];if(g2label&&g2label!=='â€” None (single genre) â€”')parts.push(g2label);if(s2label&&s2label!=='â€” None â€”')parts.push(s2label.split('(')[0].trim());
  if(chip)chip.textContent=parts.join(' + ')+' â€” '+S.blend.ratio+'% primary / '+(100-S.blend.ratio)+'% secondary';
  const descs={gospel:'Call-response structures, uplifting language, communal "we" voice, repetition as spiritual emphasis.',spoken_word:'Dense metaphor, enjambment across lines, conversational rhythm, narrative specificity, no forced rhyme.',cinematic:'Scene-setting opening lines, character names, location details, story arc across sections.',minimalist:'Maximum 6 syllables per line, no adjective padding, every word load-bearing, silence implied.',surreal:'Unexpected noun-verb pairings, impossible imagery, colour as emotion, dreamlike transitions.',confessional:'Specific names and places, uncomfortable truths, first-person vulnerability, no metaphor hiding.',political:'Clear antagonist/protagonist, call to action in chorus, historical references, collective identity.',romantic_classic:'Extended metaphor, classical imagery (seasons, light, water), volta in bridge, elevated diction.',street:'Block-specific detail, present tense action, economic pressure as subtext, community as cast.',psychedelic:'Sensory overload, dissolution of self, colour and synesthesia, questions not answers.'};
  const key=s2sel.value||'';
  document.getElementById('blend-desc').textContent=descs[key]||(parts.length?'Secondary influence active â€” writing will blend both styles proportionally.':'');
}
