    messages: [{role:'user', content:prompt}],
  };
  if (systemPrompt) body.system = systemPrompt;

  // On Vercel (served over https): use the secure server-side proxy
  // Locally (file:// or localhost): call Anthropic directly with stored key
  const onVercel = window.location.protocol === 'https:' &&
                   !window.location.hostname.includes('localhost');

  if (onVercel) {
    const res = await fetch('/api/generate', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({messages: body.messages, system: body.system, max_tokens: 4096})
    });
    const ct = res.headers.get('content-type') || '';
    if (!ct.includes('application/json')) {
      const txt = await res.text();
      console.error('Proxy error:', res.status, txt.slice(0,200));
      throw new Error('API proxy error ' + res.status + ' â€” check ANTHROPIC_API_KEY is set in Vercel Environment Variables, then Redeploy.');
    }
    if (!res.ok) {
      const e = await res.json().catch(() => ({}));
      throw new Error(e.error || 'Request failed ' + res.status);
    }
    const data = await res.json();
    return data.content?.map(c => c.text||'').join('') || '';
  }

  // LOCAL MODE â€” direct API call with stored key
  const apiKey = window._soniqKey || localStorage.getItem('soniq_api_key');
  if (!apiKey) {
    showKeyScreen();
    throw new Error('enter-key');
  }

  // OpenRouter uses OpenAI-compatible format
  const orBody = {
    model: 'anthropic/claude-sonnet-4-5',
    max_tokens: 4096,
    messages: body.messages,
  };
  if (body.system) {
    orBody.messages = [{role:'system', content: body.system}, ...body.messages];
  }

  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + apiKey,
      'HTTP-Referer': window.location.href,
      'X-Title': 'SONIQ',
    },
    body: JSON.stringify(orBody),
  });

  if (res.status === 401) {
    localStorage.removeItem('soniq_api_key');
    window._soniqKey = null;
    showKeyScreen('API key rejected â€” check it at openrouter.ai/keys');
    throw new Error('enter-key');
  }
  if (!res.ok) {
    const err = await res.text();
    throw new Error('API error ' + res.status + ': ' + err.slice(0,120));
  }
  const data = await res.json();
  return data.choices?.[0]?.message?.content || '';
}

