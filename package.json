function parseLuckyResult(raw,fusionName,meta){
  const title=parseSection(raw,'TITLE','VERDICT')||fusionName+' Song';
  const verdict=parseSection(raw,'VERDICT','LYRICS');
  const lyrics=parseSection(raw,'LYRICS','SONG PROMPT');
  const songPrompt=parseSection(raw,'SONG PROMPT','PRODUCTION BRIEF');
  const briefRaw=parseSection(raw,'PRODUCTION BRIEF','STRUCTURE MAP');
  const structure=parseSection(raw,'STRUCTURE MAP','DOPAMINE MAP');
  const dopamine=parseSection(raw,'DOPAMINE MAP','DIRECTOR NOTES');
  const notes=parseSection(raw,'DIRECTOR NOTES',null);

  const out=document.getElementById('lucky-out');
  out.style.display='block';
  out.classList.add('visible');
