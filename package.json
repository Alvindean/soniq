function saveApiKey() {
  const input = document.getElementById('key-input');
  const errEl = document.getElementById('key-error');
  const key = input?.value?.trim() || '';

  if (!key) {
    errEl.textContent = 'Please enter your API key';
    errEl.style.display = 'block';
    return;
  }
  if (!key.startsWith('sk-')) {
    errEl.textContent = 'OpenRouter keys start with sk-or- â€” get yours at openrouter.ai/keys';
    errEl.style.display = 'block';
    return;
  }

  localStorage.setItem('soniq_api_key', key);
  window._soniqKey = key;

  const screen = document.getElementById('key-screen');
  if (screen) {
    screen.style.opacity = '0';
    screen.style.transition = 'opacity 0.2s';
    setTimeout(() => screen.remove(), 200);
  }
  toast('âœ“ API key saved â€” you're ready to create!');
}

