// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// LIBRARY
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
function renderLib(){
  const search=(document.getElementById('lib-search')?.value||'').toLowerCase();
  const count=document.getElementById('lib-count');
  let songs=S.library;
  if(search) songs=songs.filter(s=>
    (s.title||'').toLowerCase().includes(search) ||
    (s.genre||'').toLowerCase().includes(search) ||
    (s.topic||'').toLowerCase().includes(search) ||
    (s.lyrics||'').toLowerCase().includes(search)
  );
  if(count) count.textContent=S.library.length+' song'+(S.library.length!==1?'s':'');
  const grid=document.getElementById('lib-grid');
  if(!grid) return;

  if(!songs.length){
    grid.innerHTML=`<div class="lib-empty">
      <div class="lib-empty-icon">ًں“ڑ</div>
      ${S.library.length
        ? `<div>No songs match "<strong>${search}</strong>"</div>`
        : `<div style="font-weight:600;color:var(--tx2);margin-bottom:6px">Your library is empty</div>
           <div style="font-size:12px;color:var(--tx3)">Generate a song and click ًں’¾ Save â€” it'll appear here</div>`
      }
    </div>`;
    return;
  }

  grid.innerHTML=songs.map(s=>{
    const date=new Date(s.ts||s.id).toLocaleDateString(undefined,{month:'short',day:'numeric',year:'numeric'});
    // Get first real lyric line as preview
    const preview=(s.lyrics||'').replace(/\[.*?\]/g,'').split('\n').map(l=>l.trim()).find(l=>l)||'No lyrics';
    // Safe ID for onclick â€” use index lookup instead of inlining ID
    const idx = S.library.findIndex(lib => lib.id === s.id);
    return`<div class="libcard" onclick="loadFromLibIdx(${idx})">
      <button class="lc-del" title="Delete" onclick="event.stopPropagation();delFromLib(${idx})">âœ•</button>
      <div class="lc-title">${escHtml(s.title||'Untitled')}</div>
      <div class="lc-meta">
        <span class="bdg bdg-cyan">${escHtml(s.genre||'?')}</span>
        <span style="color:var(--tx4);font-size:10px">${date}</span>
      </div>
      <div class="lc-topic" style="font-size:11px;color:var(--tx3);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escHtml(s.topic||'')}</div>
      <div class="lc-preview">${escHtml(preview)}</div>
    </div>`;
  }).join('');
}

function escHtml(str){
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

function loadFromLibIdx(idx){
  const song = S.library[idx];
  if(!song) return;
  loadSongIntoOutput(song);
  navTo('write');
  toast('âœ“ Loaded: '+(song.title||'Untitled'));
}

function loadSongIntoOutput(song){
  S.currentSong = song;
  const out = document.getElementById('gen-out');
  out.classList.add('visible');
  document.getElementById('loaded-banner').style.display = 'flex';
  document.getElementById('res-title').textContent = song.title || 'Untitled';
  document.getElementById('res-verdict').textContent = song.verdict || '';
  document.getElementById('res-lyrics-text').innerHTML = (song.lyrics||'').replace(/\[([^\]]+)\]/g,'<span class="tag">[$1]</span>');
  renderBrief('res', song.style||'', song.brief||'');
  document.getElementById('res-structure-text').textContent = song.structure || '';
  document.getElementById('res-dopamine-text').textContent = song.dopamine || '';
  document.getElementById('res-notes-text').textContent = song.notes || '';
  // Reset title creator state for this song
  if(titleState && titleState.res) {
    titleState.res.selected = null;
    const tc = document.getElementById('res-titles-content');
    if(tc) tc.dataset.forTitle = '';
  }
  // Reset to lyrics tab
  const firstTab = document.querySelector('.otabs .otab');
  if(firstTab) goOtab('res','lyrics', firstTab);
}

function loadFromLib(id){
  const idx = S.library.findIndex(s=>s.id===id);
  if(idx === -1) return;
  loadFromLibIdx(idx);
}

function delFromLib(idx){
  const song = S.library[idx];
  if(!song) return;
  if(!confirm(`Delete "${song.title||'Untitled'}"?`)) return;
  S.library.splice(idx, 1);
  persistLib();
  renderLib();
  toast('Song deleted');
}

function clearLib(){
  if(!confirm(`Clear all ${S.library.length} saved songs? This cannot be undone.`)) return;
  S.library = [];
  persistLib();
  renderLib();
  toast('Library cleared');
}

