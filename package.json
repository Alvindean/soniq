    document.getElementById('r-out').innerHTML=`<div class="card"><div style="font-size:13px;line-height:1.8;white-space:pre-wrap">${raw.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div></div>`;
  }catch(e){showErr('r-out',e.message);}
  btnDone('r-btn');
}

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
// TITLE CREATOR
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ

// Track which title is selected per output panel
const titleState = { res: { selected: null, custom: '' }, lres: { selected: null, custom: '' } };

async function loadTitles(prefix) {
  const contentEl = document.getElementById(prefix + '-titles-content');
  if (!contentEl) return;

  // Get the song data for this panel
  const song = prefix === 'res' ? S.currentSong : S.luckyCurrentSong;
  if (!song?.lyrics) {
    contentEl.innerHTML = `<div style="text-align:center;padding:40px;color:var(--tx4);font-size:13px">Generate a song first to get title suggestions.</div>`;
    return;
  }

  // If already loaded titles for this song, don't re-fetch
  if (contentEl.dataset.forTitle === song.title && contentEl.innerHTML.includes('tc-grid')) return;

  renderTitleShell(prefix, song);
  await generateTitles(prefix, song);
}

function renderTitleShell(prefix, song) {
  const contentEl = document.getElementById(prefix + '-titles-content');
  const ts = titleState[prefix];
  contentEl.innerHTML = `
    <div class="title-creator">
      <p class="tc-intro">10 title options generated specifically for this song â€” each from a different creative strategy. Click any title to select it, then apply it to your song. Or write your own below.</p>
      <div class="tc-generate-row">
        <button class="btn btn-gold btn-sm" id="${prefix}-regen-titles-btn" onclick="generateTitles('${prefix}',null)">ًں”„ Regenerate titles</button>
        <span style="font-size:11px;color:var(--tx4)">Current: <strong id="${prefix}-current-title-display" style="color:var(--tx2)">${song.title||'Untitled'}</strong></span>
      </div>
      <div class="tc-grid" id="${prefix}-tc-grid">
        <div style="display:flex;align-items:center;gap:10px;padding:16px 0;color:var(--tx3)">
          <span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span>
          <span class="ld-msg">Generating 10 title optionsâ€¦</span>
        </div>
      </div>
      <div class="tc-custom">
        <input type="text" class="tc-custom-input" id="${prefix}-custom-title-input"
          placeholder="Or type your own titleâ€¦"
          value="${ts.custom||''}"
          oninput="titleState['${prefix}'].custom=this.value"
        />
        <button class="btn btn-sm btn-teal" onclick="applyCustomTitle('${prefix}')">Apply Title</button>
      </div>
      <div id="${prefix}-applied-banner" class="tc-applied" style="display:none">
        âœ“ Title applied to song
      </div>
    </div>`;
  contentEl.dataset.forTitle = song.title;
}

async function generateTitles(prefix, song) {
  if (!song) {
    song = prefix === 'res' ? S.currentSong : S.luckyCurrentSong;
  }
  if (!song?.lyrics) return;

  const grid = document.getElementById(prefix + '-tc-grid');
  if (!grid) return;
  grid.innerHTML = `<div style="display:flex;align-items:center;gap:10px;padding:16px 0;color:var(--tx3)"><span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span><span class="ld-msg">Generating 10 title optionsâ€¦</span></div>`;

  const btn = document.getElementById(prefix + '-regen-titles-btn');
  if (btn) { btn._orig = btn.innerHTML; btn.disabled = true; btn.innerHTML = '<span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span>'; }

  // Sample first 400 chars of lyrics for context
  const lyricSample = (song.lyrics || '').slice(0, 400);
  const prompt = `You are a master song title writer. Analyze this song and generate exactly 10 distinct title options.

Song genre: ${song.genre || 'unknown'}
Song topic: ${song.topic || 'unknown'}
Current working title: ${song.title || 'untitled'}
Lyric sample:
${lyricSample}

Generate 10 title options, one per strategy. Each strategy must be different. Use these exact 10 types:
1. HOOK â€” A phrase pulled directly from or inspired by the most memorable lyric
2. IMAGE â€” A striking visual image from the song content
3. EMOTION â€” Names the core feeling without explaining it
4. MYSTERY â€” Intriguing, slightly cryptic â€” makes you want to listen to find out why
5. STATEMENT â€” A bold declarative line, like a thesis
6. CONTRAST â€” Two opposing ideas or words put together
7. QUESTION â€” A question the song answers
8. PLACE/TIME â€” Anchors to a specific location or moment
9. CHARACTER â€” Names a person, role, or identity central to the song
10. ABSTRACT â€” Poetic, metaphorical â€” the feeling translated to an unexpected word or phrase

Respond with a JSON array only. No markdown, no explanation outside the array:
[
  {"type":"HOOK","title":"Title Here","why":"One sentence on why this title works psychologically for this song."},
  {"type":"IMAGE","title":"Title Here","why":"..."},
  ... (all 10)
]`;

  try {
    const raw = await callClaude(prompt, 'You are a hit song title specialist. Output only valid JSON arrays. No markdown fences, no extra text.');

    // Strip markdown fences if present
    const cleaned = raw.replace(/```json\n?|\n?```/g, '').trim();
    const titles = JSON.parse(cleaned);

    renderTitleCards(prefix, titles, song);
  } catch (e) {
    grid.innerHTML = `<div style="color:var(--red);font-size:13px;padding:12px 0">âڑ ï¸ڈ Could not generate titles: ${e.message}. <button class="btn btn-sm" onclick="generateTitles('${prefix}',null)" style="margin-left:8px">Try again</button></div>`;
  }

  if (btn) { btn.disabled = false; btn.innerHTML = btn._orig; }
}

function renderTitleCards(prefix, titles, song) {
  const grid = document.getElementById(prefix + '-tc-grid');
  if (!grid) return;

  const typeClass = {
    HOOK: 'tc-type-hook', IMAGE: 'tc-type-image', EMOTION: 'tc-type-emotion',
    MYSTERY: 'tc-type-mystery', STATEMENT: 'tc-type-statement',
    CONTRAST: 'tc-type-hook', QUESTION: 'tc-type-emotion',
    'PLACE/TIME': 'tc-type-image', CHARACTER: 'tc-type-statement', ABSTRACT: 'tc-type-mystery'
  };

  const ts = titleState[prefix];

  grid.innerHTML = titles.map((t, i) => {
    const cls = typeClass[t.type] || 'tc-type-hook';
    const isSelected = ts.selected === t.title;
    return `<div class="tc-card${isSelected ? ' selected' : ''}" id="${prefix}-tc-${i}" onclick="selectTitle('${prefix}',${i},${JSON.stringify(t.title).replace(/"/g,'&quot;')})">
      <div class="tc-num">${i + 1}</div>
      <div class="tc-body">
        <div class="tc-type ${cls}">${t.type}</div>
        <div class="tc-title-text">${t.title}</div>
        <div class="tc-why">${t.why}</div>
      </div>
      <button class="tc-use-btn" onclick="event.stopPropagation();applyTitle('${prefix}','${t.title.replace(/'/g,"\\'")}')">Use this</button>
    </div>`;
  }).join('');
}

function selectTitle(prefix, idx, title) {
  const ts = titleState[prefix];
  // Deselect all
  document.querySelectorAll(`#${prefix}-tc-grid .tc-card`).forEach(c => c.classList.remove('selected'));
  // Select clicked
  const card = document.getElementById(`${prefix}-tc-${idx}`);
  if (card) card.classList.add('selected');
  ts.selected = title;
  // Update custom input with this selection
  const inp = document.getElementById(`${prefix}-custom-title-input`);
  if (inp) { inp.value = title; ts.custom = title; }
}

function applyTitle(prefix, title) {
  // Update the song title in state
  if (prefix === 'res' && S.currentSong) {
    S.currentSong.title = title;
    const el = document.getElementById('res-title');
    if (el) el.textContent = title;
  } else if (prefix === 'lres' && S.luckyCurrentSong) {
    S.luckyCurrentSong.title = title;
    const el = document.getElementById('lres-title');
    if (el) el.textContent = title;
  }
  // Update the display in the titles tab
  const display = document.getElementById(`${prefix}-current-title-display`);
  if (display) display.textContent = title;
  // Show applied banner
  const banner = document.getElementById(`${prefix}-applied-banner`);
  if (banner) { banner.style.display = 'flex'; setTimeout(() => banner.style.display = 'none', 2500); }
  toast(`âœ“ Title applied: "${title}"`);
}

function applyCustomTitle(prefix) {
  const inp = document.getElementById(`${prefix}-custom-title-input`);
  const title = inp?.value?.trim();
  if (!title) { toast('Enter a title first'); return; }
  applyTitle(prefix, title);
}

// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
