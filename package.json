// LYRIC EDITOR + SYLLABLE COUNTER
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
function loadLyricsIntoEditor(lyrics,title){
  S.editorLines=lyrics.split('\n').map(l=>({text:l,isTag:/^\[/.test(l.trim()),isEmpty:!l.trim()}));
  renderEditor();
  document.getElementById('paste-modal').style.display='none';
}
function navTo(pageId){
  // Find the nav button that navigates to this page and click it programmatically
  const btn=Array.from(document.querySelectorAll('.nb')).find(b=>b.getAttribute('onclick')===`goPg('${pageId}',this)`);
  if(btn)goPg(pageId,btn);
}

function renderEditor(){
  const body=document.getElementById('ed-body');
  if(!S.editorLines.length)return;
  let html='';
  let chorus=false;
  let sectionOpen=false;

  S.editorLines.forEach((line,i)=>{
    if(line.isEmpty){
      // Close open section before gap
      if(sectionOpen){html+='</div></div>';sectionOpen=false;}
      html+='<div style="height:8px"></div>';
      return;
    }
    if(line.isTag){
      // Close any previous open section
      if(sectionOpen){html+='</div></div>';sectionOpen=false;}
      chorus=/chorus|hook/i.test(line.text);
      html+=`<div class="lsection" style="margin-top:10px"><div class="lstag">${line.text}</div><div class="ls-lines">`;
      sectionOpen=true;
      return;
    }
    const syl=lineSyl(line.text);
    const cls=sylCls(syl,chorus);
    const escaped=line.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    html+=`<div class="lline" id="ll${i}">
      <input class="ll-input" type="text" value="${escaped}" oninput="updLine(${i},this.value)" data-chorus="${chorus}"/>
      <span class="ll-syl ${cls}" id="syl${i}">${syl>0?syl:'â€”'}</span>
      <button class="ll-regen" id="reg${i}" onclick="regenLine(${i})" title="Regenerate this line">ًں”„</button>
    </div>`;
  });
  // Close final open section
  if(sectionOpen){html+='</div></div>';}
  body.innerHTML=html||'<div style="text-align:center;padding:48px;color:var(--tx4)">No lyrics loaded</div>';
  updEdStats();
}
function updLine(i,v){
  S.editorLines[i].text=v;
  const syl=lineSyl(v);
  const chorus=document.querySelector(`#ll${i} .ll-input`)?.dataset?.chorus==='true';
  const cls=sylCls(syl,chorus);
  const el=document.getElementById('syl'+i);
  if(el){el.textContent=syl>0?syl:'â€”';el.className='ll-syl '+cls;}
  updEdStats();
}
function updEdStats(){
  const lines=S.editorLines.filter(l=>!l.isTag&&!l.isEmpty&&l.text.trim());
  const syls=lines.map(l=>lineSyl(l.text));
  const total=lines.length;
  const avg=total?Math.round(syls.reduce((a,b)=>a+b,0)/total):0;
  const over=syls.filter(s=>s>=14).length;
  ['ed-total','ed-avg','ed-over'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.textContent=[total,avg,over][i];});
}
async function regenLine(i){
  const line=S.editorLines[i];
  let tag='[Verse]';
  for(let j=i;j>=0;j--){if(S.editorLines[j]?.isTag){tag=S.editorLines[j].text;break;}}
  const ctx=S.editorLines.slice(Math.max(0,i-2),i+3).filter(l=>!l.isTag&&!l.isEmpty).map(l=>l.text).join('\n');
  const sylTarget=lineSyl(line.text);

  const regBtn=document.getElementById('reg'+i);
  if(regBtn)regBtn.disabled=true;
  const sylEl=document.getElementById('syl'+i);
  if(sylEl){sylEl.textContent='â€¦';sylEl.className='ll-syl syl-warn';}

  try{
    const result=await callClaude(
      `Section: ${tag}\nContext lines:\n${ctx}\n\nLine to improve: "${line.text}"\n\nWrite ONE replacement line. Requirements:\n- Same approximate syllable count (target: ${sylTarget} syllables)\n- Matches rhyme scheme and flow of context\n- More evocative, specific, or punchy\n- Stays true to the section type\n\nRespond with ONLY the new line, nothing else. No quotes, no explanation.`,
      'You are an expert lyricist. Write only the requested lyric line with no extra text.'
    );
    const newLine=result.trim().replace(/^["']|["']$/g,'');
    S.editorLines[i].text=newLine;
    const inp=document.querySelector(`#ll${i} .ll-input`);
    if(inp)inp.value=newLine;
    updLine(i,newLine);
    toast('âœ“ Line regenerated');
  }catch(e){toast('âڑ ï¸ڈ Regen failed: '+e.message,3000);}
  if(regBtn)regBtn.disabled=false;
}
function showPasteModal(){document.getElementById('paste-modal').style.display='block';}
function loadPasted(){const raw=document.getElementById('paste-area').value;if(!raw.trim())return;loadLyricsIntoEditor(raw,'Pasted Song');}
function copyEdited(){const text=S.editorLines.map(l=>l.text).join('\n');navigator.clipboard.writeText(text).then(()=>toast('âœ“ Edited lyrics copied'));}
function saveEdited(){
  const lyrics=S.editorLines.map(l=>l.text).join('\n');
  const song={
    id:Date.now(),
    title:(S.currentSong?.title||'Song')+' (edited)',
    genre:S.currentSong?.genre||'',
    topic:S.currentSong?.topic||'',
    lyrics,
    style:S.currentSong?.style||'',
    brief:S.currentSong?.brief||'',
    structure:S.currentSong?.structure||'',
    dopamine:S.currentSong?.dopamine||'',
    notes:S.currentSong?.notes||'',
    ts:Date.now()
  };
  S.library.unshift(song);
  persistLib();
  toast('âœ“ Edited version saved to library');
}

