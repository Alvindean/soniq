function parseSection(raw, key, nextKey){
  // Try all common formats Claude might use for headers
  const patterns=[
    key+':\n', key+': \n', key+':  \n',  // header then newline
    key+': ',                              // header space content (same line)
    key+':',                               // bare header
  ];
  let start=-1;
  for(const p of patterns){
    const i=raw.indexOf(p);
    if(i!==-1){start=i+p.length;break;}
  }
  if(start===-1)return'';
  // Skip any leading newlines after header
  while(start<raw.length&&raw[start]==='\n')start++;
  let end=raw.length;
  if(nextKey){
    // Find next header â€” try all patterns for the next key too
    for(const p of[nextKey+':\n',nextKey+': \n',nextKey+':  \n',nextKey+': ',nextKey+':']){
      const ni=raw.indexOf(p,start);
      if(ni>start){end=ni;break;}
    }
  }
  return raw.slice(start,end).trim();
}

function parseSongResult(raw,genre,topic){
  const title=parseSection(raw,'TITLE','VERDICT')||'Your Song';
  const verdict=parseSection(raw,'VERDICT','LYRICS');
  const lyrics=parseSection(raw,'LYRICS','SONG PROMPT');
  const songPrompt=parseSection(raw,'SONG PROMPT','PRODUCTION BRIEF');
  const briefRaw=parseSection(raw,'PRODUCTION BRIEF','STRUCTURE MAP');
  const structure=parseSection(raw,'STRUCTURE MAP','DOPAMINE MAP');
  const dopamine=parseSection(raw,'DOPAMINE MAP','DIRECTOR NOTES');
  const notes=parseSection(raw,'DIRECTOR NOTES',null);

  document.getElementById('res-title').textContent=title;
  document.getElementById('res-verdict').textContent=verdict;
  document.getElementById('res-lyrics-text').innerHTML=(lyrics||raw).replace(/\[([^\]]+)\]/g,'<span class="tag">[$1]</span>');
  document.getElementById('res-structure-text').textContent=structure||'';
  document.getElementById('res-dopamine-text').textContent=dopamine||'';
  document.getElementById('res-notes-text').textContent=notes||'';

  // Render Production Brief
  renderBrief('res', songPrompt, briefRaw);

  S.currentSong={title,verdict,lyrics,style:songPrompt,brief:briefRaw,structure,dopamine,notes,genre,topic,ts:Date.now()};
  toast('âœ“ Song generated: "'+title+'"');
}

// â”€â”€â”€ BRIEF RENDERER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function parseBriefSection(text, key) {
  const idx = text.indexOf(key + ':');
  if (idx === -1) return '';
  const start = idx + key.length + 1;
  const nextMatch = text.slice(start).search(/\n[A-Z][A-Z &]+:/);
  const end = nextMatch === -1 ? text.length : start + nextMatch;
  return text.slice(start, end).trim();
}

function renderBrief(prefix, songPrompt, briefRaw) {
  const el = document.getElementById(prefix + '-brief-content');
  if (!el) return;

  const raw = briefRaw || '';
  const corePrompt = parseBriefSection(raw, 'CORE PROMPT') || songPrompt || '';
  const tempoKey   = parseBriefSection(raw, 'TEMPO & KEY');
  const arrange    = parseBriefSection(raw, 'ARRANGEMENT BLUEPRINT');
  const vocal      = parseBriefSection(raw, 'VOCAL DIRECTION');
  const sonic      = parseBriefSection(raw, 'SONIC REFERENCES');
  const platTips   = parseBriefSection(raw, 'PLATFORM TIPS');

  const cpBtn = (id, label='Copy') =>
    `<button class="brief-copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('${id}').textContent).then(()=>toast('âœ“ Copied'))">${label}</button>`;

  el.innerHTML = `
    <!-- MAIN PROMPT â€” hero section -->
    <div class="brief-hero">
      <div class="brief-hero-label">
        <span>Song Prompt</span>
        <span style="font-size:10px;color:var(--tx3);font-weight:400">Copy this into your AI music platform's style/genre field</span>
        ${cpBtn('brief-core-prompt', 'Copy Prompt')}
      </div>
      <div class="brief-prompt-box" id="brief-core-prompt">${corePrompt}</div>
      <div class="brief-prompt-charcount" id="brief-charcount">${corePrompt.length}/200 characters</div>
    </div>

    <div class="brief-grid">
      ${tempoKey ? `<div class="brief-block brief-block-amber">
        <div class="brief-block-label">ًںژڑ Tempo & Key</div>
        <div class="brief-block-body">${tempoKey}</div>
      </div>` : ''}
      ${sonic ? `<div class="brief-block brief-block-violet">
        <div class="brief-block-label">ًں”ٹ Sonic References</div>
        <div class="brief-block-body">${sonic}</div>
      </div>` : ''}
    </div>

    ${arrange ? `<div class="brief-section">
      <div class="brief-section-label">ًںژ¸ Arrangement Blueprint</div>
      <div class="brief-section-body">${arrange.replace(/\//g,'<br>â†’ ')}</div>
    </div>` : ''}

    ${vocal ? `<div class="brief-section">
      <div class="brief-section-label">ًںژ¤ Vocal Direction</div>
      <div class="brief-section-body">${vocal.replace(/\//g,'<br>â†’ ')}</div>
    </div>` : ''}

    ${platTips ? `<div class="brief-section brief-tips">
      <div class="brief-section-label">ًں’، Platform Tips</div>
      <div class="brief-section-body">${platTips.split(/\n|\d\.\s/).filter(t=>t.trim()).map(t=>`<div class="brief-tip">â†’ ${t.trim()}</div>`).join('')}</div>
    </div>` : ''}

    ${!corePrompt&&!raw ? `<div style="padding:40px;text-align:center;color:var(--tx3);font-size:13px">Generate a song to see the Production Brief</div>` : ''}
  `;

  // live char count colouring
  const cc = el.querySelector('#brief-charcount');
  if (cc) {
    const len = corePrompt.length;
    cc.style.color = len > 200 ? 'var(--red)' : len > 160 ? 'var(--amber)' : 'var(--green)';
  }
}

function saveLib(){
  if(!S.currentSong?.lyrics){toast('Generate a song first');return;}

  // Deduplicate: if this song is already saved (same title + lyrics), update it
  const existing = S.library.findIndex(s =>
    s.title === S.currentSong.title && s.lyrics === S.currentSong.lyrics
  );

  const song = {
    ...S.currentSong,
    id: existing >= 0 ? S.library[existing].id : Date.now(),
    ts: Date.now(),
  };

  if(existing >= 0){
    S.library[existing] = song;
    toast('âœ“ Song updated in library');
  } else {
    S.library.unshift(song);
    toast('âœ“ Saved to library');
  }

  if(S.library.length > 200) S.library = S.library.slice(0, 200);
  persistLib();
  updateSaveBtn('gen-save-btn', true);
}

function saveLuckyToLib(){
  if(!S.luckyCurrentSong){toast('Generate a lucky song first');return;}

  const existing = S.library.findIndex(s =>
    s.title === S.luckyCurrentSong.title && s.lyrics === S.luckyCurrentSong.lyrics
  );

  const song = {
