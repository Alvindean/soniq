}

function persistLib(){
  try {
    localStorage.setItem('soniq_library', JSON.stringify(S.library));
    // Also keep old key in sync for backwards compat
    localStorage.setItem('sce5_lib', JSON.stringify(S.library));
  } catch(e) {
    // localStorage full â€” trim and retry
    S.library = S.library.slice(0, 50);
    localStorage.setItem('soniq_library', JSON.stringify(S.library));
    toast('âڑ ï¸ڈ Library trimmed to 50 songs â€” storage full');
  }
  updateLibBadge();
}

function updateLibBadge(){
  const count = S.library.length;
  // Update count in the library page header
  const el = document.getElementById('lib-count');
  if(el) el.textContent = count + ' song' + (count !== 1 ? 's' : '');
  // Update nav badge if one exists
  const navBadge = document.getElementById('nav-lib-count');
  if(navBadge){
    navBadge.textContent = count > 0 ? count : '';
    navBadge.style.display = count > 0 ? 'inline-block' : 'none';
  }
}

function updateSaveBtn(btnId, saved){
  const btn = document.getElementById(btnId);
  if(!btn) return;
  if(saved){
    const orig = btn.innerHTML;
    btn.innerHTML = 'âœ“ Saved';
    btn.style.background = 'var(--green)';
    btn.style.borderColor = 'var(--greenline)';
    btn.style.color = '#050505';
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.style.background = '';
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 2000);
  }
}

