// BIBLE
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
function renderBiblePills(){
  const el=document.getElementById('bible-pills');if(!el||el.innerHTML)return;
  const allG=[{id:'pop',label:'Pop',new:false},{id:'hiphop',label:'Hip-Hop',new:false},{id:'rnb',label:'R&B',new:false},{id:'rock',label:'Rock',new:false},{id:'country',label:'Country',new:false},{id:'edm',label:'EDM',new:false},{id:'folk',label:'Folk',new:false},{id:'latin',label:'Latin',new:false},{id:'metal',label:'Metal',new:false},{id:'jazz',label:'Jazz',new:false},{id:'ss',label:'Singer-Songwriter',new:true},{id:'altrock',label:'Alt-Rock',new:true},{id:'reggae',label:'Reggae',new:true},{id:'afrobeats',label:'Afrobeats',new:true},{id:'blues',label:'Blues',new:true},{id:'punk',label:'Punk',new:true},{id:'latin',label:'Latin',new:false},{id:'reggaeton',label:'Reggaeton',new:true},{id:'kpop',label:'K-Pop',new:true}];
  allG.forEach(g=>{
    const p=document.createElement('span');
    p.className='pill'+(g.new?' new':'')+(g.id==='ss'?' on':'');
    p.textContent=g.label+(g.new?' âœ¦':'');
    p.onclick=()=>{el.querySelectorAll('.pill').forEach(x=>x.classList.remove('on'));p.classList.add('on');showBible(g.id,g.label);};
    el.appendChild(p);
  });
  showBible('ss','Singer-Songwriter');
}
function showBible(id,label){
  const b=GENRE_BIBLE[id];
  if(!b){document.getElementById('bible-content').innerHTML=`<div class="card"><p style="font-size:13px;color:var(--tx2)">Use the <strong>Analyzer</strong> for an AI-powered deep dive into ${label} songs. Genre Bible covers the 6 newest genres.</p></div>`;return;}
  document.getElementById('bible-content').innerHTML=`<div class="card bible"><div style="font-size:18px;font-weight:800;margin-bottom:12px;letter-spacing:-0.4px">${label}</div><h4>Genre DNA</h4><p>${b.dna}</p><h4>Structure Approach</h4><p>${b.structure}</p><h4>Suno Production Tips</h4><p>${b.suno}</p><h4>Key Songwriting Rules</h4><ul>${b.keys.map(k=>`<li>${k}</li>`).join('')}</ul><h4>Artists to Study</h4><p class="artists">${b.artists}</p></div>`;
}

