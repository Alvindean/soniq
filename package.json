// RATE SONG
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
async function rateSong(){
  const input=document.getElementById('r-input').value.trim();
  const genre=document.getElementById('r-genre').value;
  if(!input){document.getElementById('r-input').focus();return;}
  const prompt=`Rate this song as a music expert, neuroscientist, and hit songwriter.\n\nInput: ${input}\n${genre?`Genre: ${genre}`:''}\n\nScore each dimension (1-10) with a 2-sentence rationale:\n- Hook Strength\n- Structural Efficiency\n- Emotional Impact\n- Lyric Quality\n- Commercial Appeal\n- Production Innovation\n- Cultural Impact\n\nOVERALL SCORE: X/10\nVERDICT: [one compelling sentence]\nWHY IT WORKS: [2-3 key structural/psychological reasons]\nWHAT WOULD IMPROVE IT: [2-3 specific suggestions]\nPRODUCTION RECREATION TIPS: [how to recreate this song's essence in Suno]`;
  btnLoad('r-btn','Ratingâ€¦');
  document.getElementById('r-out').innerHTML='<div class="card"><div style="display:flex;align-items:center;gap:8px;padding:8px 0"><span class="ld"><span class="ldd"></span><span class="ldd"></span><span class="ldd"></span></span><span class="ld-msg">Rating songâ€¦</span></div></div>';
