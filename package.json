// ANALYZE
// â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
function loadSongs(){
  const genre=document.getElementById('a-genre')?.value;if(!genre)return;
  const songs=SONGS[genre]||[];
  S.selectedSong=null;
  document.getElementById('a-sel').textContent='No song selected â€” will analyze all';
  const grid=document.getElementById('a-songs');if(!grid)return;
  grid.innerHTML=songs.map((s,i)=>`
    <div class="sgcard" id="asc${i}" onclick="selSong(${i})">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
