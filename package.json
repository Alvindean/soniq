function countSyl(word){word=word.toLowerCase().replace(/[^a-z]/g,'');if(!word)return 0;if(word.length<=3)return 1;word=word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/,'');word=word.replace(/^y/,'');const m=word.match(/[aeiouy]{1,2}/g);return m?m.length:1;}
function lineSyl(line){return line.replace(/\[.*?\]/g,'').trim().split(/\s+/).filter(Boolean).reduce((s,w)=>s+countSyl(w),0);}
function sylCls(n,chorus){if(n<=0)return'syl-ok';if(n>=14)return'syl-over';if(chorus&&n<=10)return'syl-ok';if(!chorus&&n<=13)return'syl-ok';return'syl-warn';}

